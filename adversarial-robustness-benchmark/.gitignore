# Datasets — track the committed clean benchmark set, the typographic
# poisoned set, and the corruption-set MANIFESTS (15,000 JPEGs themselves
# are regenerated locally via `scripts/generate_datasets.py --corruptions`).
# The parquet cache and CIFAR-100 stay ignored.
data/*
!data/.gitkeep
!data/clean/
!data/poisoned/
data/poisoned/*
!data/poisoned/typographic/
!data/poisoned/corruptions/
# Corruption-axis: ~450 MiB of regenerable images. Manifests + dir structure
# are tracked so the layout is reproducible without the binaries.
data/poisoned/corruptions/*/images/
data/poisoned/corruptions/preview_grid.png

# Exported attack images (inspection only — large, regenerable, not tracked)
attack_previews/
attack_previews.zip

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Notebook checkpoints
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

.claude/
