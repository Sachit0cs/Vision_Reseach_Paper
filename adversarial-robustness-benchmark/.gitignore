# Datasets — track the committed clean benchmark set and the typographic
# poisoned set (one shared, model-agnostic poisoned set generated once and
# checked in). The parquet cache, CIFAR-100 and other future poisoned sets
# (patch, corruptions) stay ignored.
data/*
!data/.gitkeep
!data/clean/
!data/poisoned/
data/poisoned/*
!data/poisoned/typographic/

# Exported attack images (inspection only — large, regenerable, not tracked)
attack_previews/
attack_previews.zip

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Notebook checkpoints
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

.claude/
